{
  "name": "n8n-nodes-tollara",
  "version": "2.0.0",
  "description": "n8n community nodes for Tollara: Trigger (HMAC webhook), Invoke, Progress, Complete, Validate Service Key",
  "keywords": [
    "n8n-community-node-package",
    "n8n",
    "tollara"
  ],
  "license": "MIT",
  "homepage": "https://github.com/tollara/tollara-sdk",
  "author": {},
  "repository": {
    "type": "git",
    "url": "https://github.com/tollara/tollara-sdk.git"
  },
  "main": "index.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch"
  },
  "files": [
    "dist"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/TollaraApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/TollaraTrigger/TollaraTrigger.node.js",
      "dist/nodes/TollaraInvoke/TollaraInvoke.node.js",
      "dist/nodes/TollaraProgress/TollaraProgress.node.js",
      "dist/nodes/TollaraComplete/TollaraComplete.node.js",
      "dist/nodes/TollaraValidateKey/TollaraValidateKey.node.js"
    ],
    "packageId": "n8n-nodes-tollara"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "n8n-workflow": "^1.0.0",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "@tollara/service-sdk": "file:../sdk-js"
  },
  "peerDependencies": {
    "n8n-workflow": "*"
  }
}
