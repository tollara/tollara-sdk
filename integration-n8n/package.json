{
  "name": "n8n-nodes-tollara",
  "version": "0.0.21",
  "description": "n8n community nodes for Tollara: Verify Request, Invoke, Job Status/Result, Progress, Complete, Validate Key, Report Usage, Estimate Usage",
  "keywords": [
    "n8n-community-node-package",
    "n8n",
    "tollara"
  ],
  "license": "MIT",
  "homepage": "https://github.com/tollara/tollara-sdk/tree/main/integration-n8n",
  "bugs": {
    "url": "https://github.com/tollara/tollara-sdk/issues"
  },
  "author": {
    "name": "Tollara",
    "email": "support@tollara.ai"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tollara/tollara-sdk.git",
    "directory": "integration-n8n"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "main": "index.js",
  "scripts": {
    "build": "node scripts/clean-dist.mjs && tsc && node scripts/bundle-sdk.mjs && node scripts/sync-icons.mjs",
    "build:tests": "tsc -p ../tests/integration-n8n/tsconfig.json",
    "dev": "tsc --watch",
    "lint": "n8n-node lint",
    "lint:fix": "n8n-node lint --fix",
    "test": "npm run build && npm run build:tests && node scripts/run-tests.mjs",
    "release": "node scripts/release.mjs",
    "prepublishOnly": "n8n-node prerelease",
    "apply:local-fixture": "node scripts/apply-local-fixture.mjs",
    "deploy:local": "powershell -ExecutionPolicy Bypass -File ./deploy-local.ps1",
    "deploy:npm": "powershell -ExecutionPolicy Bypass -File ./deploy-npm.ps1",
    "repair:workflows": "powershell -ExecutionPolicy Bypass -File ./docker/strip-stale-credentials.ps1"
  },
  "files": [
    "dist",
    "index.js",
    "example-workflows/*.json",
    "example-workflows/README.md",
    "LICENSE"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "strict": true,
    "credentials": [
      "dist/credentials/TollaraApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/TollaraVerifyRequest/TollaraVerifyRequest.node.js",
      "dist/nodes/TollaraInvoke/TollaraInvoke.node.js",
      "dist/nodes/TollaraJobStatus/TollaraJobStatus.node.js",
      "dist/nodes/TollaraJobResult/TollaraJobResult.node.js",
      "dist/nodes/TollaraProgress/TollaraProgress.node.js",
      "dist/nodes/TollaraComplete/TollaraComplete.node.js",
      "dist/nodes/TollaraValidateKey/TollaraValidateKey.node.js",
      "dist/nodes/TollaraReportUsage/TollaraReportUsage.node.js",
      "dist/nodes/TollaraEstimateUsage/TollaraEstimateUsage.node.js"
    ],
    "packageId": "n8n-nodes-tollara"
  },
  "devDependencies": {
    "@n8n/node-cli": "^0.23.0",
    "@tollara/service-sdk": "^0.0.2",
    "@types/node": "^20.11.0",
    "esbuild": "^0.25.0",
    "eslint": "^9.39.0",
    "n8n-workflow": "^1.0.0",
    "release-it": "^20.0.0",
    "typescript": "^5.3.3"
  },
  "peerDependencies": {
    "n8n-workflow": "*"
  },
  "publishConfig": {
    "provenance": true
  },
  "release-it": {
    "git": {
      "tagName": "n8n-nodes-tollara-v${version}",
      "commitMessage": "chore(n8n-nodes-tollara): release ${version}",
      "requireBranch": "main",
      "requireCleanWorkingDir": true,
      "requireUpstream": true,
      "requireCommits": true,
      "commit": true,
      "tag": true,
      "push": true,
      "changelog": "npx auto-changelog --stdout --unreleased --commit-limit false -u --hide-credit"
    },
    "github": {
      "release": true
    },
    "npm": {
      "publishPath": ".",
      "publish": false
    },
    "hooks": {
      "before:init": "npm run build && npm run lint",
      "after:bump": "npx auto-changelog -p"
    }
  }
}
