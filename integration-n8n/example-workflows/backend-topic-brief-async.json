      "typeVersion": 1,
      "position": [3300, 180]    },
    {
      "parameters": {
        "jsCode": "const parsed = $('Parse Async Envelope').first().json;\nconst raw = $input.first().json;\nconst wiki = raw.body ?? raw;\nconst topic = parsed.topic;\nconst title = wiki.title ?? topic;\nconst summary = wiki.extract ?? 'No Wikipedia summary found for this topic.';\nconst source = wiki.content_urls?.desktop?.page ?? null;\nconst report = [\n  '# Topic brief: ' + topic,\n  '',\n  '**Title:** ' + title,\n  source ? '**Source:** ' + source : '',\n  '',\n  '## Summary',\n  summary,\n  '',\n  '---',\n  '_Generated by n8n + Tollara_',\n].filter(Boolean).join('\\n');\n\nreturn [{\n  json: {\n    requestId: parsed.requestId,\n    progressUrl: parsed.progressUrl,\n    callbackUrl: parsed.callbackUrl,\n    report,\n  },\n}];"
      },
