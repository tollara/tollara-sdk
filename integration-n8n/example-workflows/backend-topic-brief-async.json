        "responseBody": "={{ { status: 'error', message: 'Forbidden — subscription does not grant access' } }}",
        "options": { "responseCode": 403 }
      },
      "id": "b2c3d4e5-0002-4000-8000-00000000001f",
      "name": "Respond Forbidden",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1.1,
      "position": [900, 420]
    },
    {
      "parameters": {
        "jsCode": "const item = $input.first();\nlet raw;\nconst bin = item.binary?.data;\nif (bin?.data) {\n  raw = JSON.parse(Buffer.from(bin.data, 'base64').toString('utf8'));\n} else if (typeof $json.body === 'string') {\n  raw = JSON.parse($json.body || '{}');\n} else {\n  raw = $json.body ?? {};\n}\n\nlet parseOk = true;\nlet parseError = null;\nlet requestId = null;\nlet progressUrl = null;\nlet callbackUrl = null;\nlet topic = null;\n\nif (raw.request_id == null && raw.topic != null && raw.payload == null) {\n  parseOk = false;\n  parseError = 'Sync-shaped body — use async invoke';\n} else {\n  const inner = raw.payload != null\n    ? (typeof raw.payload === 'string' ? JSON.parse(raw.payload || '{}') : raw.payload)\n    : {};\n  topic = (inner.topic ?? '').trim();\n  requestId = raw.request_id ?? null;\n  progressUrl = raw.progress_url ?? null;\n  callbackUrl = raw.callback_url ?? null;\n  if (!topic) { parseOk = false; parseError = 'Missing topic'; }\n  else if (!requestId) { parseOk = false; parseError = 'Missing request_id'; }\n}\n\nreturn [{ json: { ...$json, parseOk, parseError, requestId, progressUrl, callbackUrl, topic, userContext: $json.userContext } }];"
      },
