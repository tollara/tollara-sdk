{
  "name": "Tollara Demo — URL Metadata API (proxied sync)",
  "nodes": [
    {
      "parameters": {
        "content": "## URL Metadata API\n\n**Tollara:** proxied sync service\n\n**Webhook path:** `url-metadata`\n\n**Invoke body:** `{ \"url\": \"https://example.com\" }`\n\n**Credential:** Tollara Proxied API",
        "height": 220,
        "width": 420
      },
      "id": "a1b2c3d4-0001-4000-8000-000000000001",
      "name": "Sticky Note",
      "type": "n8n-nodes-base.stickyNote",
      "typeVersion": 1,
      "position": [-200, -120]
    },
    {
